# Server configuration
PORT=3000

# Database connection (example for Postgres on Render/Aiven)
DATABASE_URL=postgres://username:password@host:5432/dbname

# JWT or session secret (for authentication)
JWT_SECRET=super_secret_key_here

# Email OTP service (if you’re sending verification codes)
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_email_app_password

# Any third-party API keys (optional, add as needed)
SOME_API_KEY=your_api_key_here
